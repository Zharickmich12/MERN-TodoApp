# Copia este archivo a .env y ajusta los valores
# En la terminal: copy .env.example .env  (Windows)  o  cp .env.example .env  (Mac/Linux)

# URI de MongoDB
# Local: mongodb://localhost:27017/todoapp
# Atlas: mongodb+srv://usuario:password@cluster.xxxxx.mongodb.net/todoapp
MONGODB_URI=mongodb://localhost:27017/todoapp

# Puerto del servidor (opcional, default 5000)
PORT=5000
